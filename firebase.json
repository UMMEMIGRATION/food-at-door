{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "target": "customer",
      "public": "apps/customer/out",
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "restaurant",
      "public": "apps/restaurant/out",
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "admin",
      "public": "apps/admin/out",
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true, "port": 4000 }
  }
}
