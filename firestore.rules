rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helper functions
    // -----------------------------------------------------------------------

    /** Is the request from a signed-in user? */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Is the requesting user the owner of this document? */
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    /** Does the requesting user have the 'admin' role? */
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** Does the requesting user have the 'restaurant_owner' role? */
    function isRestaurantOwner(restaurantId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    /** Does the requesting user have the 'driver' role? */
    function isDriver() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/drivers/$(request.auth.uid));
    }

    /** Prevent clients from writing sensitive computed fields */
    function noSensitiveFieldsChanged() {
      return !request.resource.data.keys().hasAny([
        'commissionAmount', 'restaurantEarnings'
      ]) && (
        !request.resource.data.keys().hasAny(['paymentStatus']) ||
        request.resource.data.paymentStatus == 'pending' ||
        request.resource.data.paymentStatus == 'Pending' ||
        request.resource.data.paymentStatus == 'Paid' ||
        request.resource.data.paymentStatus == 'paid'
      );
    }

    // -----------------------------------------------------------------------
    // users collection
    // -----------------------------------------------------------------------
    match /users/{userId} {
      // Users can read and write their own document
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // -----------------------------------------------------------------------
    // customers collection
    // -----------------------------------------------------------------------
    match /customers/{userId} {
      allow read:   if isSignedIn() || isAdmin();
      allow write:  if isAdmin();
    }

    // -----------------------------------------------------------------------
    // restaurants collection
    // -----------------------------------------------------------------------
    match /restaurants/{restaurantId} {
      allow read: if isAdmin() ||
                     resource.data.status == 'approved' ||
                     (isSignedIn() && resource.data.ownerId == request.auth.uid);

      // Owners can create their own restaurant document, admins can create any
      allow create: if isAdmin() ||
                       (isSignedIn() && request.resource.data.ownerId == request.auth.uid);

      // Owners can update their own restaurant, admins can update any
      allow update: if isAdmin() ||
                       (isSignedIn() && resource.data.ownerId == request.auth.uid);

      // Only admins can delete restaurants
      allow delete: if isAdmin();

      // Categories and Menu Items subcollections
      match /menuCategories/{categoryId} {
        allow read: if true;
        allow write: if isAdmin() || isRestaurantOwner(restaurantId);
      }

      match /menuItems/{itemId} {
        allow read: if true;
        allow write: if isAdmin() || isRestaurantOwner(restaurantId);
      }
    }

    // -----------------------------------------------------------------------
    // menu_items collection
    // -----------------------------------------------------------------------
    match /menu_items/{itemId} {
      // Any signed-in user can read available items
      allow read: if isSignedIn();

      // Only the owning restaurant or admin can write
      allow create: if isAdmin() ||
                       isRestaurantOwner(request.resource.data.restaurantId);
      allow update: if isAdmin() ||
                       isRestaurantOwner(resource.data.restaurantId);
      allow delete: if isAdmin() ||
                       isRestaurantOwner(resource.data.restaurantId);
    }

    // -----------------------------------------------------------------------
    // orders collection
    // -----------------------------------------------------------------------
    match /orders/{orderId} {
      // Customer who placed it, the assigned restaurant, the driver, admin,
      // or any signed-in driver if the order is unassigned and in one of the active matching states.
      allow read: if isSignedIn();

      // Only customers can place orders; financial fields are server-computed
      allow create: if isSignedIn() &&
                       request.resource.data.customerId == request.auth.uid &&
                       noSensitiveFieldsChanged();

      allow update: if isSignedIn();
      allow delete: if false; // Orders are never deleted
    }

    // -----------------------------------------------------------------------
    // drivers collection
    // -----------------------------------------------------------------------
    match /drivers/{driverId} {
      // Driver can read/update their own doc; admin has full access
      allow read:   if isOwner(driverId) || isAdmin();
      allow create: if isOwner(driverId) || isAdmin();
      allow update: if isOwner(driverId) || isAdmin();
      allow delete: if isAdmin();
    }

    // -----------------------------------------------------------------------
    // reviews collection
    // -----------------------------------------------------------------------
    match /reviews/{reviewId} {
      // Anyone signed in can read visible reviews
      allow read: if isSignedIn() && resource.data.isVisible == true || isAdmin();

      // Only the customer who placed the order can write a review
      allow create: if isSignedIn() &&
                       request.resource.data.customerId == request.auth.uid;

      // Restaurant owner can add ownerReply; admin can toggle visibility
      allow update: if isAdmin() ||
                       isRestaurantOwner(resource.data.restaurantId);

      allow delete: if isAdmin();
    }

    // -----------------------------------------------------------------------
    // payouts collection
    // -----------------------------------------------------------------------
    match /payouts/{payoutId} {
      // Restaurant owners and drivers can read their own payouts
      allow read: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );

      // Only admin / Cloud Functions can create or update payouts
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // coupons collection
    // -----------------------------------------------------------------------
    match /coupons/{couponId} {
      // Any signed-in user can read active coupons
      allow read: if isSignedIn() && resource.data.isActive == true || isAdmin();

      // Only admin can manage coupons
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // -----------------------------------------------------------------------
    // bankDetails collection
    // -----------------------------------------------------------------------
    match /bankDetails/{bankDetailId} {
      allow read: if isAdmin() || 
                     (isSignedIn() && isRestaurantOwner(resource.data.restaurantId));
      allow create: if isAdmin() || 
                      (isSignedIn() && isRestaurantOwner(request.resource.data.restaurantId));
      allow update: if isAdmin() || 
                      (isSignedIn() && isRestaurantOwner(resource.data.restaurantId));
    }

    // -----------------------------------------------------------------------
    // withdrawalRequests collection
    // -----------------------------------------------------------------------
    match /withdrawalRequests/{requestId} {
      allow read: if isAdmin() || 
                     (isSignedIn() && isRestaurantOwner(resource.data.restaurantId));
      allow create: if isAdmin() || 
                      (isSignedIn() && isRestaurantOwner(request.resource.data.restaurantId));
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // -----------------------------------------------------------------------
    // driverLocations collection
    // -----------------------------------------------------------------------
    match /driverLocations/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == driverId;
    }

    // -----------------------------------------------------------------------
    // wallet collection
    // -----------------------------------------------------------------------
    match /wallet/{driverId} {
      allow read: if isSignedIn() && request.auth.uid == driverId || isAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == driverId || isAdmin();

      match /cod_transactions/{txId} {
        allow read: if isSignedIn() && request.auth.uid == driverId || isAdmin();
        allow create, update: if isSignedIn() && request.auth.uid == driverId || isAdmin();
      }

      match /transactions/{txId} {
        allow read: if isSignedIn() && request.auth.uid == driverId || isAdmin();
        allow create, update: if isSignedIn() && request.auth.uid == driverId || isAdmin();
      }
    }

    // -----------------------------------------------------------------------
    // Additional Collections for COD Recharge
    // -----------------------------------------------------------------------
    match /codTransactions/{id} {
      allow read: if isSignedIn() && (resource.data.driverId == request.auth.uid || request.auth.uid == id) || isAdmin();
      allow write: if isSignedIn() && (request.resource.data.driverId == request.auth.uid || request.auth.uid == id) || isAdmin();
    }

    match /walletTransactions/{id} {
      allow read: if isSignedIn() && (resource.data.driverId == request.auth.uid || request.auth.uid == id) || isAdmin();
      allow write: if isSignedIn() && (request.resource.data.driverId == request.auth.uid || request.auth.uid == id) || isAdmin();
    }

    match /payments/{id} {
      allow read: if isSignedIn() && (resource.data.driverId == request.auth.uid || request.auth.uid == id) || isAdmin();
      allow write: if isSignedIn() && (request.resource.data.driverId == request.auth.uid || request.auth.uid == id) || isAdmin();
    }

    match /rechargeHistory/{id} {
      allow read: if isSignedIn() && (resource.data.driverId == request.auth.uid || request.auth.uid == id) || isAdmin();
      allow write: if isSignedIn() && (request.resource.data.driverId == request.auth.uid || request.auth.uid == id) || isAdmin();
    }

    // -----------------------------------------------------------------------
    // Centralized supportChats collections
    // -----------------------------------------------------------------------
    match /customerSupportChats/{customerId} {
      allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (request.auth.uid == customerId || isAdmin());
      }
    }

    match /restaurantSupportChats/{restaurantId} {
      allow read, write: if isSignedIn() && (isRestaurantOwner(restaurantId) || request.auth.uid == restaurantId || isAdmin());
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (isRestaurantOwner(restaurantId) || request.auth.uid == restaurantId || isAdmin());
      }
    }

    match /driverSupportChats/{driverId} {
      allow read, write: if isSignedIn() && (request.auth.uid == driverId || isAdmin());
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (request.auth.uid == driverId || isAdmin());
      }
    }

    // -----------------------------------------------------------------------
    // liveTracking collection
    // -----------------------------------------------------------------------
    match /liveTracking/{trackingId} {
      allow read, write: if isSignedIn();
    }

  }
}

